<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Card style for elevated panels -->
  <ControlTheme x:Key="PremiumCard" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource BackgroundPrimaryBrush}"/>
    <Setter Property="CornerRadius" Value="10"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="20"/>
    <Setter Property="BoxShadow" Value="0 1 3 0 #0000001A"/>
  </ControlTheme>

</ResourceDictionary>
