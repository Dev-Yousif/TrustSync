<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TrustSync.Desktop.ViewModels.Pages"
             x:Class="TrustSync.Desktop.Views.Pages.ExpensesView"
             x:DataType="vm:ExpensesViewModel">

  <Panel>
  <Panel Classes.dialog="{Binding IsConfirmDialogOpen}" Classes.editor="{Binding IsEditorOpen}">
    <Panel.Styles>
      <Style Selector="Panel.dialog">
        <Setter Property="Effect"><Setter.Value><BlurEffect Radius="6"/></Setter.Value></Setter>
      </Style>
      <Style Selector="Panel.editor">
        <Setter Property="Effect"><Setter.Value><BlurEffect Radius="6"/></Setter.Value></Setter>
      </Style>
    </Panel.Styles>
  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="16">

      <Border Background="{DynamicResource BackgroundPrimaryBrush}" CornerRadius="14" Padding="20,16"
              BoxShadow="0 1 4 0 #00000008">
        <Grid ColumnDefinitions="*,Auto">
          <TextBox Text="{Binding SearchText}" Watermark="Search expenses..."
                   Width="300" HorizontalAlignment="Left"
                   Background="{DynamicResource BackgroundSecondaryBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
                   CornerRadius="8" Padding="12,0" Height="38" FontSize="13"
                   VerticalContentAlignment="Center"/>
          <Button Grid.Column="1" Command="{Binding OpenCreateCommand}"
                  Theme="{StaticResource BtnPrimary}" CornerRadius="8" Padding="18,9">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="+" FontSize="16" FontWeight="Bold" Margin="0,-2,0,0"/>
              <TextBlock Text="Add Expense"/>
            </StackPanel>
          </Button>
        </Grid>
      </Border>

      <Border Background="{DynamicResource BackgroundPrimaryBrush}" CornerRadius="14" Padding="24,20"
              BoxShadow="0 1 4 0 #00000008">
        <StackPanel Spacing="4">
          <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
            <TextBlock Text="Expense Transactions" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <Border Grid.Column="1" Background="{DynamicResource BackgroundSecondaryBrush}" CornerRadius="6" Padding="10,4">
              <TextBlock Text="{Binding Items.Count, StringFormat={}{0} records}"
                         FontSize="11" Foreground="{DynamicResource TextMutedBrush}" FontWeight="Medium"/>
            </Border>
          </Grid>

          <ItemsControl ItemsSource="{Binding Items}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Padding="0,12" BorderBrush="{DynamicResource BackgroundHoverBrush}" BorderThickness="0,0,0,1">
                  <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                    <Border Grid.Column="0" Width="38" Height="38" CornerRadius="10"
                            Background="{DynamicResource ErrorTintBrush}" Margin="0,0,14,0" VerticalAlignment="Center">
                      <Path Data="{StaticResource IconExpense}" Stroke="{DynamicResource ErrorBrush}" StrokeThickness="1.8"
                            Width="16" Height="16" Stretch="Uniform"
                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Description}" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Background="{DynamicResource ErrorTintBrush}" CornerRadius="4" Padding="6,2">
                          <TextBlock Text="{Binding ExpenseType}" FontSize="10" Foreground="{DynamicResource ErrorBrush}" FontWeight="Medium"/>
                        </Border>
                        <Border Background="{DynamicResource BackgroundHoverBrush}" CornerRadius="4" Padding="6,2">
                          <TextBlock Text="{Binding CategoryName}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="Medium"/>
                        </Border>
                        <TextBlock Text="{Binding CompanyClientName}" FontSize="11" Foreground="{DynamicResource TextLightBrush}"
                                   IsVisible="{Binding CompanyClientName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   VerticalAlignment="Center"/>
                      </StackPanel>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{Binding Date, StringFormat=\{0:MMM dd\, yyyy\}}"
                               FontSize="12" Foreground="{DynamicResource TextLightBrush}" VerticalAlignment="Center" Margin="16,0"/>
                    <TextBlock Grid.Column="3"
                               FontSize="15" FontWeight="Bold" Foreground="{DynamicResource ErrorBrush}"
                               VerticalAlignment="Center" Margin="12,0">
                      <TextBlock.Text>
                        <MultiBinding StringFormat="{}{1}{0:N2}">
                          <Binding Path="Amount"/>
                          <Binding Path="CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/>
                        </MultiBinding>
                      </TextBlock.Text>
                    </TextBlock>
                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center" Margin="8,0,0,0">
                      <Button Command="{Binding $parent[ItemsControl].((vm:ExpensesViewModel)DataContext).OpenEditCommand}"
                              CommandParameter="{Binding}" Background="Transparent" BorderThickness="0"
                              Padding="8,5" CornerRadius="6" Cursor="Hand">
                        <TextBlock Text="Edit" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="Medium"/>
                      </Button>
                      <Button Command="{Binding $parent[ItemsControl].((vm:ExpensesViewModel)DataContext).RequestDeleteCommand}"
                              CommandParameter="{Binding}" Background="Transparent" BorderThickness="0"
                              Padding="8,5" CornerRadius="6" Cursor="Hand">
                        <TextBlock Text="Del" FontSize="11" Foreground="{DynamicResource ErrorBrush}" FontWeight="Medium"/>
                      </Button>
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <StackPanel IsVisible="{Binding !Items.Count}" HorizontalAlignment="Center"
                      Margin="0,40" Spacing="10">
            <Border Width="48" Height="48" CornerRadius="12" Background="{DynamicResource BackgroundHoverBrush}" HorizontalAlignment="Center">
              <Path Data="{StaticResource IconExpense}" Stroke="{DynamicResource TextLightBrush}" StrokeThickness="1.8"
                    Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="No expenses recorded" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="Track personal and work-related expenses." FontSize="13" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Center"/>
            <Button Command="{Binding OpenCreateCommand}"
                    Theme="{StaticResource BtnPrimary}" CornerRadius="8" Padding="18,9"
                    HorizontalAlignment="Center" Margin="0,8,0,0">
              <TextBlock Text="+ Add Expense"/>
            </Button>
          </StackPanel>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>

  <!-- Loading Overlay -->
  <Border IsVisible="{Binding IsBusy}" Background="{DynamicResource BackgroundOverlayBrush}" CornerRadius="12">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
      <ProgressBar IsIndeterminate="True" Width="120" Foreground="{DynamicResource AccentPrimaryBrush}" Background="{DynamicResource BorderDefaultBrush}"/>
      <TextBlock Text="Loading..." FontSize="13" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
    </StackPanel>
  </Border>
  </Panel>

  <!-- Confirm Dialog -->
  <Border IsVisible="{Binding IsConfirmDialogOpen}" Background="{DynamicResource BackgroundModalBrush}" CornerRadius="12">
    <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="400"
            Background="{DynamicResource BackgroundPrimaryBrush}" CornerRadius="16" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
            BoxShadow="0 24 48 0 #30000000" ClipToBounds="True">
      <StackPanel>
        <StackPanel Margin="32,32,32,0" Spacing="14" HorizontalAlignment="Center">
          <Border Width="56" Height="56" CornerRadius="28" Background="{DynamicResource ErrorTintBrush}" HorizontalAlignment="Center">
            <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource ErrorTintBrush}" HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock Text="!" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource ErrorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </Border>
          <TextBlock Text="{Binding ConfirmDialogTitle}" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" TextAlignment="Center"/>
          <TextBlock Text="{Binding ConfirmDialogMessage}" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" TextAlignment="Center" LineHeight="20" Margin="0,0,0,4"/>
        </StackPanel>
        <Border Margin="0,24,0,0" Padding="24,18" BorderBrush="{DynamicResource BackgroundHoverBrush}" BorderThickness="0,1,0,0" Background="{DynamicResource BackgroundSecondaryBrush}">
          <Grid ColumnDefinitions="*,10,*">
            <Button Grid.Column="0" Command="{Binding ConfirmDialogNoCommand}"
                    Theme="{StaticResource BtnSecondary}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="42">
              <TextBlock Text="Cancel"/>
            </Button>
            <Button Grid.Column="2" Command="{Binding ConfirmDialogYesCommand}"
                    Theme="{StaticResource BtnDanger}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="42">
              <TextBlock Text="Delete"/>
            </Button>
          </Grid>
        </Border>
      </StackPanel>
    </Border>
  </Border>

  <!-- Editor -->
  <Border IsVisible="{Binding IsEditorOpen}" Background="{DynamicResource BackgroundModalBrush}" CornerRadius="12">
    <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="520"
            Background="{DynamicResource BackgroundPrimaryBrush}" CornerRadius="16" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
            BoxShadow="0 24 48 0 #30000000" ClipToBounds="True">
      <StackPanel>
        <Grid ColumnDefinitions="Auto,*,Auto" Margin="28,24,20,0">
          <Border Width="42" Height="42" CornerRadius="12" Background="{DynamicResource ErrorTintBrush}">
            <Path Data="{StaticResource IconExpense}" Stroke="{DynamicResource ErrorBrush}" StrokeThickness="1.8"
                  Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center" Spacing="2">
            <TextBlock Text="Expense" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Track your spending" FontSize="12" Foreground="{DynamicResource TextLightBrush}"/>
          </StackPanel>
          <Button Grid.Column="2" Command="{Binding CloseEditorCommand}" Background="Transparent" BorderThickness="0" Padding="10" CornerRadius="8" Cursor="Hand" VerticalAlignment="Top">
            <TextBlock Text="✕" FontSize="16" Foreground="{DynamicResource TextLightBrush}"/>
          </Button>
        </Grid>
        <Border Height="1" Background="{DynamicResource BackgroundHoverBrush}" Margin="0,20,0,0"/>

        <ScrollViewer HorizontalScrollBarVisibility="Disabled" MaxHeight="420">
          <StackPanel Margin="28,20,28,8" Spacing="16">
            <StackPanel Spacing="6">
              <TextBlock Text="DESCRIPTION" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}"/>
              <TextBox Text="{Binding EditorDescription}" Watermark="What did you spend on?"/>
              <TextBlock Text="{Binding DescriptionError}" FontSize="11" Foreground="{DynamicResource ErrorBrush}" IsVisible="{Binding HasDescriptionError}"/>
            </StackPanel>
            <Grid ColumnDefinitions="*,12,*,12,*">
              <StackPanel Grid.Column="0" Spacing="6">
                <TextBlock Text="AMOUNT" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}"/>
                <TextBox Text="{Binding EditorAmount}"/>
                <TextBlock Text="{Binding AmountError}" FontSize="11" Foreground="{DynamicResource ErrorBrush}" IsVisible="{Binding HasAmountError}"/>
              </StackPanel>
              <StackPanel Grid.Column="2" Spacing="6">
                <TextBlock Text="CURRENCY" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}"/>
                <ComboBox ItemsSource="{Binding Currencies}" SelectedItem="{Binding EditorCurrency}"
                          HorizontalAlignment="Stretch" FontSize="13" Background="{DynamicResource BackgroundPrimaryBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14,10" MinHeight="44"/>
              </StackPanel>
              <StackPanel Grid.Column="4" Spacing="6">
                <TextBlock Text="TYPE" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}"/>
                <ComboBox ItemsSource="{Binding ExpenseTypes}" SelectedItem="{Binding EditorExpenseType}"
                          HorizontalAlignment="Stretch" FontSize="13" Background="{DynamicResource BackgroundPrimaryBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14,10" MinHeight="44"/>
              </StackPanel>
            </Grid>
            <TextBlock Text="{Binding ConversionPreview}"
                       IsVisible="{Binding ConversionPreview, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       FontSize="12" Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" Margin="0,-10,0,0"/>
            <Grid ColumnDefinitions="*,12,*">
              <StackPanel Grid.Column="0" Spacing="6">
                <TextBlock Text="CATEGORY" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}"/>
                <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding EditorCategory}"
                          DisplayMemberBinding="{Binding Name}" HorizontalAlignment="Stretch" FontSize="13" Background="{DynamicResource BackgroundPrimaryBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14,10" MinHeight="44"/>
                <TextBlock Text="{Binding CategoryError}" FontSize="11" Foreground="{DynamicResource ErrorBrush}" IsVisible="{Binding HasCategoryError}"/>
              </StackPanel>
              <StackPanel Grid.Column="2" Spacing="6">
                <TextBlock Text="DATE" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}"/>
                <DatePicker SelectedDate="{Binding EditorDate}" HorizontalAlignment="Stretch"/>
              </StackPanel>
            </Grid>
            <Grid ColumnDefinitions="*,12,*">
              <StackPanel Grid.Column="0" Spacing="6">
                <TextBlock Text="COMPANY" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}"/>
                <ComboBox ItemsSource="{Binding Companies}" SelectedItem="{Binding EditorCompany}"
                          DisplayMemberBinding="{Binding Name}" HorizontalAlignment="Stretch" FontSize="13" Background="{DynamicResource BackgroundPrimaryBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14,10" MinHeight="44"/>
              </StackPanel>
              <StackPanel Grid.Column="2" Spacing="6">
                <TextBlock Text="PROJECT" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}"/>
                <ComboBox ItemsSource="{Binding Projects}" SelectedItem="{Binding EditorProject}"
                          DisplayMemberBinding="{Binding Name}" HorizontalAlignment="Stretch" FontSize="13" Background="{DynamicResource BackgroundPrimaryBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14,10" MinHeight="44"/>
              </StackPanel>
            </Grid>
            <TextBlock Text="{Binding ErrorMessage}" IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Foreground="{DynamicResource ErrorBrush}" FontSize="12"/>
          </StackPanel>
        </ScrollViewer>

        <Border Padding="24,18" BorderBrush="{DynamicResource BackgroundHoverBrush}" BorderThickness="0,1,0,0" Background="{DynamicResource BackgroundSecondaryBrush}">
          <Grid ColumnDefinitions="*,10,*">
            <Button Grid.Column="0" Command="{Binding CloseEditorCommand}"
                    Theme="{StaticResource BtnSecondary}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="42">
              <TextBlock Text="Cancel"/>
            </Button>
            <Button Grid.Column="2" Command="{Binding SaveCommand}"
                    Theme="{StaticResource BtnPrimary}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="42"
                    IsEnabled="{Binding !IsBusy}">
              <TextBlock Text="Save"/>
            </Button>
          </Grid>
        </Border>
      </StackPanel>
    </Border>
  </Border>

  <!-- Toast Notification -->
  <Border IsVisible="{Binding IsToastVisible}" HorizontalAlignment="Center" VerticalAlignment="Bottom"
          Margin="0,0,0,24" Padding="16,10" CornerRadius="10" Background="{DynamicResource BackgroundPrimaryBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" BoxShadow="0 4 16 0 #40000000">
    <TextBlock Text="{Binding ToastMessage}" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
  </Border>

  </Panel>
</UserControl>
