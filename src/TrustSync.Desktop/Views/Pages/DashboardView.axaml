<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TrustSync.Desktop.ViewModels.Pages"
             x:Class="TrustSync.Desktop.Views.Pages.DashboardView"
             x:DataType="vm:DashboardViewModel">

  <Panel>
  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="16" Margin="0,0,10,0">

      <!-- Welcome Header -->
      <Border Background="Transparent" Padding="0"
              IsVisible="{Binding Summary.UserDisplayName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Panel Grid.Column="0" Width="64" Height="64" Margin="0,0,16,0">
            <Border Width="64" Height="64" CornerRadius="12"
                    IsVisible="{Binding !HasProfileImage}"
                    Background="{DynamicResource AccentCardGradientBrush}">
              <TextBlock Text="{Binding UserInitial}" FontSize="20" FontWeight="Bold"
                         Foreground="{DynamicResource AccentCardTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Border Width="64" Height="64" CornerRadius="12" ClipToBounds="True"
                    IsVisible="{Binding HasProfileImage}">
              <Image Source="{Binding ProfileBitmap}" Stretch="UniformToFill"/>
            </Border>
          </Panel>
          <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
            <TextBlock Text="{Binding Greeting}" FontSize="14" Foreground="{DynamicResource TextLightBrush}" FontWeight="Medium"/>
            <TextBlock Text="{Binding Summary.UserDisplayName}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
          </StackPanel>
          <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Spacing="6">
            <TextBlock Text="{Binding TodayDate}" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" FontWeight="Medium"
                       HorizontalAlignment="Right"/>
            <TextBlock Text="{Binding TodayDay}" FontSize="11" Foreground="{DynamicResource TextLightBrush}"
                       HorizontalAlignment="Right"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Month Navigation + Quick Expense -->
      <Border Background="{DynamicResource BackgroundPrimaryBrush}" CornerRadius="12" Padding="12,8"
              BoxShadow="0 1 4 0 #00000008">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
          <Button Grid.Column="0" Command="{Binding PreviousMonthCommand}"
                  Background="Transparent" BorderThickness="0" Padding="10,6" Cursor="Hand" CornerRadius="8">
            <Path Data="M15 18l-6-6 6-6" Stroke="{DynamicResource TextMutedBrush}" StrokeThickness="2"
                  Width="14" Height="14" Stretch="Uniform"/>
          </Button>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                      HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="{Binding SelectedMonthLabel}" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
            <Button Command="{Binding GoToCurrentMonthCommand}"
                    IsVisible="{Binding !IsCurrentMonth}"
                    Background="{DynamicResource BackgroundHoverBrush}" BorderThickness="0" Padding="10,4" Cursor="Hand" CornerRadius="6">
              <TextBlock Text="Today" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}"/>
            </Button>
          </StackPanel>
          <Button Grid.Column="2" Command="{Binding NextMonthCommand}"
                  Background="Transparent" BorderThickness="0" Padding="10,6" Cursor="Hand" CornerRadius="8"
                  IsEnabled="{Binding !IsCurrentMonth}">
            <Path Data="M9 18l6-6-6-6" Stroke="{DynamicResource TextMutedBrush}" StrokeThickness="2"
                  Width="14" Height="14" Stretch="Uniform"/>
          </Button>
          <Button Grid.Column="3" Command="{Binding OpenQuickExpenseCommand}"
                  Cursor="Hand" CornerRadius="8" Padding="12,6" Margin="8,0,0,0" BorderThickness="0"
                  Background="{DynamicResource AccentCardGradientBrush}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="+" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AccentCardTextBrush}" VerticalAlignment="Center"/>
              <TextBlock Text="Quick Expense" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource AccentCardTextBrush}" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </Grid>
      </Border>

      <!-- KPI Cards -->
      <Grid ColumnDefinitions="*,*,*,*">
        <Border Grid.Column="0" Background="{DynamicResource BackgroundPrimaryBrush}" CornerRadius="14" Padding="22,20"
                Margin="0,0,8,0" BoxShadow="0 1 4 0 #00000008">
          <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
            <TextBlock Grid.Row="0" Text="Income" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextMutedBrush}"/>
            <Border Grid.Row="0" Grid.Column="1" Width="32" Height="32" CornerRadius="8"
                    Background="{DynamicResource BackgroundSelectedBrush}" HorizontalAlignment="Right">
              <Path Data="{StaticResource IconIncome}" Stroke="{DynamicResource AccentPrimaryBrush}" StrokeThickness="2"
                    Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Grid.Row="1" Grid.ColumnSpan="2" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,10,0,0">
              <TextBlock.Text>
                <MultiBinding StringFormat="{}{1}{0:N2}">
                  <Binding Path="Summary.MonthlyIncome"/>
                  <Binding Path="Summary.CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/>
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
            <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding SelectedMonthLabel}"
                       FontSize="11" Foreground="{DynamicResource TextLightBrush}" Margin="0,4,0,0"/>
          </Grid>
        </Border>
        <Border Grid.Column="1" Background="{DynamicResource BackgroundPrimaryBrush}" CornerRadius="14" Padding="22,20"
                Margin="4,0" BoxShadow="0 1 4 0 #00000008">
          <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
            <TextBlock Grid.Row="0" Text="Expenses" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextMutedBrush}"/>
            <Border Grid.Row="0" Grid.Column="1" Width="32" Height="32" CornerRadius="8"
                    Background="{DynamicResource BackgroundSelectedBrush}" HorizontalAlignment="Right">
              <Path Data="{StaticResource IconExpense}" Stroke="{DynamicResource AccentPrimaryBrush}" StrokeThickness="2"
                    Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Grid.Row="1" Grid.ColumnSpan="2" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,10,0,0">
              <TextBlock.Text>
                <MultiBinding StringFormat="{}{1}{0:N2}">
                  <Binding Path="Summary.MonthlyExpenses"/>
                  <Binding Path="Summary.CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/>
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
            <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding SelectedMonthLabel}"
                       FontSize="11" Foreground="{DynamicResource TextLightBrush}" Margin="0,4,0,0"/>
          </Grid>
        </Border>
        <Border Grid.Column="2" Background="{DynamicResource BackgroundPrimaryBrush}" CornerRadius="14" Padding="22,20"
                Margin="4,0" BoxShadow="0 1 4 0 #00000008">
          <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
            <TextBlock Grid.Row="0" Text="Savings" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextMutedBrush}"/>
            <Border Grid.Row="0" Grid.Column="1" Width="32" Height="32" CornerRadius="8"
                    Background="{DynamicResource BackgroundSelectedBrush}" HorizontalAlignment="Right">
              <Path Data="{StaticResource IconSavings}" Stroke="{DynamicResource AccentPrimaryBrush}" StrokeThickness="2"
                    Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Grid.Row="1" Grid.ColumnSpan="2" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,10,0,0">
              <TextBlock.Text>
                <MultiBinding StringFormat="{}{1}{0:N2}">
                  <Binding Path="Summary.MonthlySavings"/>
                  <Binding Path="Summary.CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/>
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
            <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="Total saved"
                       FontSize="11" Foreground="{DynamicResource TextLightBrush}" Margin="0,4,0,0"/>
          </Grid>
        </Border>
        <Border Grid.Column="3" CornerRadius="14" Padding="22,20"
                Margin="8,0,0,0" BoxShadow="0 4 12 0 #20202020"
                Background="{DynamicResource AccentCardGradientBrush}">
          <Grid RowDefinitions="Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Text="Net Balance" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource AccentCardSubtextBrush}"/>
            <TextBlock Grid.Row="1" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AccentCardTextBrush}" Margin="0,10,0,0">
              <TextBlock.Text>
                <MultiBinding StringFormat="{}{1}{0:N2}">
                  <Binding Path="Summary.NetBalance"/>
                  <Binding Path="Summary.CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/>
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
            <TextBlock Grid.Row="2" Text="After deductions" FontSize="11" Foreground="{DynamicResource AccentCardSubtextBrush}" Margin="0,4,0,0"/>
          </Grid>
        </Border>
      </Grid>

      <!-- Quick Stats Bar -->
      <Border Background="{DynamicResource BackgroundPrimaryBrush}" CornerRadius="14" Padding="0" BoxShadow="0 1 4 0 #00000008">
        <Grid ColumnDefinitions="*,Auto,*,Auto,*">
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14" HorizontalAlignment="Center" Margin="24,16">
            <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource WarningTintBrush}">
              <Path Data="{StaticResource IconDeductions}" Stroke="#D97706" StrokeThickness="1.8"
                    Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center" Spacing="0">
              <TextBlock FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}">
                <TextBlock.Text>
                  <MultiBinding StringFormat="{}{1}{0:N2}">
                    <Binding Path="Summary.MonthlyDeductions"/>
                    <Binding Path="Summary.CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/>
                  </MultiBinding>
                </TextBlock.Text>
              </TextBlock>
              <TextBlock Text="Deductions" FontSize="11" Foreground="{DynamicResource TextLightBrush}"/>
            </StackPanel>
          </StackPanel>
          <Border Grid.Column="1" Width="1" Background="{DynamicResource BackgroundHoverBrush}" Margin="0,12"/>
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="14" HorizontalAlignment="Center" Margin="24,16">
            <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource BackgroundSelectedBrush}">
              <Path Data="{StaticResource IconProjects}" Stroke="{DynamicResource AccentPrimaryBrush}" StrokeThickness="1.8"
                    Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center" Spacing="0">
              <TextBlock Text="{Binding Summary.ActiveProjects}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock Text="Active Projects" FontSize="11" Foreground="{DynamicResource TextLightBrush}"/>
            </StackPanel>
          </StackPanel>
          <Border Grid.Column="3" Width="1" Background="{DynamicResource BackgroundHoverBrush}" Margin="0,12"/>
          <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="14" HorizontalAlignment="Center" Margin="24,16">
            <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource BackgroundSelectedBrush}">
              <Path Data="{StaticResource IconCompanies}" Stroke="{DynamicResource AccentPrimaryBrush}" StrokeThickness="1.8"
                    Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center" Spacing="0">
              <TextBlock Text="{Binding Summary.CompaniesCount}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock Text="Companies" FontSize="11" Foreground="{DynamicResource TextLightBrush}"/>
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Recent Transactions + Expenses by Category -->
      <Grid ColumnDefinitions="3*,2*">
        <Border Grid.Column="0" Background="{DynamicResource BackgroundPrimaryBrush}" CornerRadius="14" Padding="24,20"
                Margin="0,0,8,0" BoxShadow="0 1 4 0 #00000008">
          <StackPanel Spacing="16">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="Recent Transactions" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
              <Border Grid.Column="1" Background="{DynamicResource BackgroundSecondaryBrush}" CornerRadius="6" Padding="10,4">
                <TextBlock Text="This month" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" FontWeight="Medium"/>
              </Border>
            </Grid>
            <ItemsControl ItemsSource="{Binding RecentTransactions}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Padding="0,10" BorderBrush="{DynamicResource BackgroundHoverBrush}" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                      <Border Grid.Column="0" Width="36" Height="36" CornerRadius="10"
                              Background="{DynamicResource BackgroundSelectedBrush}" Margin="0,0,14,0" VerticalAlignment="Center">
                        <Path Data="{StaticResource IconIncome}" Stroke="{DynamicResource AccentPrimaryBrush}" StrokeThickness="1.8"
                              Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Border>
                      <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Description}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextLightBrush}">
                          <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} · {1:MMM dd}">
                              <Binding Path="CategoryOrSource"/>
                              <Binding Path="Date"/>
                            </MultiBinding>
                          </TextBlock.Text>
                        </TextBlock>
                      </StackPanel>
                      <TextBlock Grid.Column="2" FontSize="14" FontWeight="Bold" VerticalAlignment="Center">
                        <TextBlock.Text>
                          <MultiBinding StringFormat="{}{1}{0:N2}">
                            <Binding Path="Amount"/>
                            <Binding Path="CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/>
                          </MultiBinding>
                        </TextBlock.Text>
                        <TextBlock.Foreground>
                          <MultiBinding><Binding Path="IsIncome"/></MultiBinding>
                        </TextBlock.Foreground>
                      </TextBlock>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="No transactions yet. Start by adding income or expenses."
                       IsVisible="{Binding !RecentTransactions.Count}"
                       FontSize="13" Foreground="{DynamicResource TextLightBrush}" Margin="0,16" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>
        <Border Grid.Column="1" Background="{DynamicResource BackgroundPrimaryBrush}" CornerRadius="14" Padding="24,20"
                Margin="8,0,0,0" BoxShadow="0 1 4 0 #00000008">
          <StackPanel Spacing="16">
            <TextBlock Text="Expenses by Category" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <ItemsControl ItemsSource="{Binding ExpenseByCategory}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Padding="0,8">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                      <Border Grid.Column="0" Width="10" Height="10" CornerRadius="3"
                              Background="{Binding ColorHex}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="1" Text="{Binding Category}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center">
                          <TextBlock.Text>
                            <MultiBinding StringFormat="{}{1}{0:N2}">
                              <Binding Path="Amount"/>
                              <Binding Path="$parent[ItemsControl].((vm:DashboardViewModel)DataContext).Summary.CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/>
                            </MultiBinding>
                          </TextBlock.Text>
                        </TextBlock>
                        <Border Background="{DynamicResource BackgroundHoverBrush}" CornerRadius="4" Padding="6,2">
                          <TextBlock Text="{Binding Percentage, StringFormat={}{0:F0}%}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                        </Border>
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="No expenses recorded this month."
                       IsVisible="{Binding !ExpenseByCategory.Count}"
                       FontSize="13" Foreground="{DynamicResource TextLightBrush}" Margin="0,16" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>
      </Grid>


    </StackPanel>
  </ScrollViewer>

  <!-- Quick Expense Overlay -->
  <Border IsVisible="{Binding IsQuickExpenseOpen}" Background="{DynamicResource BackgroundModalBrush}">
    <Border Background="{DynamicResource BackgroundPrimaryBrush}" CornerRadius="16" Padding="28,24"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            Width="420" BoxShadow="0 16 48 0 #30000000">
      <StackPanel Spacing="16">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Text="Quick Expense" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
          <Button Grid.Column="1" Command="{Binding CloseQuickExpenseCommand}"
                  Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
            <TextBlock Text="X" FontSize="14" Foreground="{DynamicResource TextLightBrush}" FontWeight="Bold"/>
          </Button>
        </Grid>
        <StackPanel Spacing="4">
          <TextBlock Text="DESCRIPTION" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}"/>
          <TextBox Text="{Binding QuickExpenseDescription}" Watermark="e.g. Coffee, Lunch, Transport"/>
        </StackPanel>
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" Spacing="4">
            <TextBlock Text="AMOUNT" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}"/>
            <TextBox Text="{Binding QuickExpenseAmount}"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="4" Margin="10,0,0,0">
            <TextBlock Text="CURRENCY" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}"/>
            <ComboBox ItemsSource="{Binding Currencies}" SelectedItem="{Binding QuickExpenseCurrency}" Width="90"/>
          </StackPanel>
        </Grid>
        <StackPanel Spacing="4">
          <TextBlock Text="CATEGORY" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}"/>
          <ComboBox ItemsSource="{Binding ExpenseCategories}"
                    SelectedItem="{Binding QuickExpenseCategory}" HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
              <DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>
        <TextBlock Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Foreground="{DynamicResource ErrorBrush}" FontSize="12"/>
        <Button Command="{Binding SaveQuickExpenseCommand}" HorizontalAlignment="Stretch"
                Cursor="Hand" CornerRadius="10" Padding="0,12" BorderThickness="0"
                Background="{DynamicResource AccentCardGradientBrush}">
          <TextBlock Text="Add Expense" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentCardTextBrush}" HorizontalAlignment="Center"/>
        </Button>
      </StackPanel>
    </Border>
  </Border>

  <!-- Loading Overlay -->
  <Border IsVisible="{Binding IsBusy}" Background="{DynamicResource BackgroundOverlayBrush}" CornerRadius="12">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
      <ProgressBar IsIndeterminate="True" Width="120" Foreground="{DynamicResource AccentPrimaryBrush}" Background="{DynamicResource BorderDefaultBrush}"/>
      <TextBlock Text="Loading..." FontSize="13" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
    </StackPanel>
  </Border>

  </Panel>
</UserControl>
