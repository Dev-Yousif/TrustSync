<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TrustSync.Desktop.Views.Pages.PlaceholderView">
  <Grid Background="{DynamicResource BackgroundSecondaryBrush}">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
      <Border Width="64" Height="64" CornerRadius="32"
              Background="{DynamicResource BackgroundHoverBrush}" HorizontalAlignment="Center">
        <TextBlock Text="🚧" FontSize="28"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Border>
      <TextBlock x:Name="TitleText" Text="Coming Soon"
                 FontSize="20" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
      <TextBlock Text="This section is under development."
                 FontSize="14" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
    </StackPanel>
  </Grid>
</UserControl>
