<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TrustSync.Desktop.ViewModels.Pages"
             x:Class="TrustSync.Desktop.Views.Pages.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <Panel>
  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="16" MaxWidth="600">

      <!-- Error -->
      <TextBlock Text="{Binding ErrorMessage}"
                 IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                 Foreground="#DC2626" FontSize="13" Margin="4,0"/>

      <!-- Profile Card -->
      <Border Background="White" CornerRadius="14" Padding="24,20"
              BoxShadow="0 1 4 0 #00000008">
        <StackPanel Spacing="16">
          <TextBlock Text="Profile" FontSize="16" FontWeight="SemiBold" Foreground="#111827"/>
          <Grid ColumnDefinitions="Auto,*">
            <!-- Avatar preview -->
            <Panel Grid.Column="0" Width="72" Height="72" Margin="0,0,20,0">
              <!-- Fallback: initial circle -->
              <Border Width="72" Height="72" CornerRadius="36"
                      IsVisible="{Binding ProfileImagePath, Converter={x:Static StringConverters.IsNullOrEmpty}}">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#202020" Offset="0"/>
                    <GradientStop Color="#404040" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="?" FontSize="28" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <!-- Image avatar -->
              <Border Width="72" Height="72" CornerRadius="36" ClipToBounds="True"
                      IsVisible="{Binding ProfileImagePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <Image Source="{Binding ProfileBitmap}" Stretch="UniformToFill"/>
              </Border>
            </Panel>
            <!-- Buttons -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8">
              <TextBlock Text="Profile Picture" FontSize="14" FontWeight="SemiBold" Foreground="#111827"/>
              <TextBlock Text="JPG, PNG or BMP. Recommended 200x200px." FontSize="11" Foreground="#9CA3AF"/>
              <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                <Button Click="OnPickProfileImage"
                        Background="#202020" Foreground="#FFFFFF" FontSize="12" FontWeight="SemiBold"
                        CornerRadius="8" Padding="14,7" Cursor="Hand" BorderThickness="0">
                  <TextBlock Text="Upload Image"/>
                </Button>
                <Button Command="{Binding RemoveProfileImageCommand}"
                        IsVisible="{Binding ProfileImagePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Background="Transparent" BorderBrush="#E5E7EB" BorderThickness="1"
                        Foreground="#6B7280" FontSize="12" CornerRadius="8" Padding="14,7" Cursor="Hand">
                  <TextBlock Text="Remove"/>
                </Button>
              </StackPanel>
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- General Settings Card -->
      <Border Background="White" CornerRadius="14" Padding="24,20"
              BoxShadow="0 1 4 0 #00000008">
        <StackPanel Spacing="16">
          <TextBlock Text="General" FontSize="16" FontWeight="SemiBold" Foreground="#111827"/>

          <Grid ColumnDefinitions="*,200">
            <TextBlock Text="Display Name" FontSize="14" Foreground="#374151" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding UserDisplayName}" Watermark="Your name"
                     HorizontalAlignment="Stretch" MinHeight="44" FontSize="13" Background="#FFFFFF" Foreground="#111827"
                     BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="12,0" VerticalContentAlignment="Center"/>
          </Grid>

          <Grid ColumnDefinitions="*,200">
            <TextBlock Text="Default Currency" FontSize="14" Foreground="#374151" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" ItemsSource="{Binding Currencies}" SelectedItem="{Binding DefaultCurrency}"
                      HorizontalAlignment="Stretch" MinHeight="44" FontSize="13" Background="#FFFFFF" Foreground="#111827"
                      BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8"/>
          </Grid>

          <Grid ColumnDefinitions="*,200">
            <TextBlock Text="Auto-Lock Timeout (minutes)" FontSize="14" Foreground="#374151" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" ItemsSource="{Binding TimeoutOptions}" SelectedItem="{Binding AutoLockTimeout}"
                      HorizontalAlignment="Stretch" MinHeight="44" FontSize="13" Background="#FFFFFF" Foreground="#111827"
                      BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8"/>
          </Grid>

          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Spacing="2">
              <TextBlock Text="Start with Windows" FontSize="14" Foreground="#374151"/>
              <TextBlock Text="Automatically launch TrustSync when you log in" FontSize="11" Foreground="#9CA3AF"/>
            </StackPanel>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoStartup}"
                          OnContent="" OffContent=""
                          VerticalAlignment="Center"/>
          </Grid>

          <Button Command="{Binding SaveSettingsCommand}" HorizontalAlignment="Right"
                  Background="#202020" Foreground="#FFFFFF" FontSize="13" FontWeight="SemiBold"
                  CornerRadius="8" Padding="18,9" Cursor="Hand" IsEnabled="{Binding !IsBusy}" BorderThickness="0">
            <TextBlock Text="Save Settings"/>
          </Button>
        </StackPanel>
      </Border>

      <!-- Exchange Rates Card -->
      <Border Background="White" CornerRadius="14" Padding="24,20"
              BoxShadow="0 1 4 0 #00000008">
        <StackPanel Spacing="16">
          <TextBlock Text="Exchange Rates" FontSize="16" FontWeight="SemiBold" Foreground="#111827"/>

          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Spacing="4">
              <TextBlock Text="Last Updated" FontSize="14" Foreground="#374151"/>
              <TextBlock Text="{Binding LastRateRefresh}" FontSize="13" Foreground="#6B7280"/>
            </StackPanel>
            <Button Grid.Column="1" Command="{Binding RefreshRatesCommand}"
                    IsEnabled="{Binding !IsRefreshingRates}"
                    Background="#202020" Foreground="#FFFFFF" FontSize="13" FontWeight="SemiBold"
                    CornerRadius="8" Padding="18,9" Cursor="Hand" BorderThickness="0" VerticalAlignment="Center">
              <TextBlock Text="Refresh Rates"/>
            </Button>
          </Grid>

          <TextBlock Text="Rates are fetched from Open ExchangeRate API (free, no key needed). They auto-refresh every 24 hours when you add a transaction."
                     FontSize="12" Foreground="#9CA3AF" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <!-- Change Password Card -->
      <Border Background="White" CornerRadius="14" Padding="24,20"
              BoxShadow="0 1 4 0 #00000008">
        <StackPanel Spacing="16">
          <TextBlock Text="Change Password" FontSize="16" FontWeight="SemiBold" Foreground="#111827"/>

          <StackPanel Spacing="6">
            <TextBlock Text="CURRENT PASSWORD" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
            <TextBox PasswordChar="&#x25CF;" Text="{Binding CurrentPassword}"/>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="NEW PASSWORD" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
            <TextBox PasswordChar="&#x25CF;" Text="{Binding NewPassword}"/>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="CONFIRM NEW PASSWORD" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
            <TextBox PasswordChar="&#x25CF;" Text="{Binding ConfirmNewPassword}"/>
          </StackPanel>

          <Button Command="{Binding ChangePasswordCommand}" HorizontalAlignment="Right"
                  Background="Transparent" BorderBrush="#DC2626" BorderThickness="1"
                  Foreground="#DC2626" FontSize="13" FontWeight="SemiBold"
                  CornerRadius="8" Padding="18,9" Cursor="Hand" IsEnabled="{Binding !IsBusy}">
            <TextBlock Text="Change Password"/>
          </Button>
        </StackPanel>
      </Border>

      <!-- Danger Zone Card -->
      <Border Background="White" CornerRadius="14" Padding="24,20"
              BoxShadow="0 1 4 0 #00000008" BorderBrush="#FCA5A5" BorderThickness="1">
        <StackPanel Spacing="16">
          <StackPanel Spacing="4">
            <TextBlock Text="Danger Zone" FontSize="16" FontWeight="SemiBold" Foreground="#DC2626"/>
            <TextBlock Text="This action will permanently delete all your data (income, expenses, projects, companies, etc.). Your account and settings will be preserved."
                       FontSize="12" Foreground="#9CA3AF" TextWrapping="Wrap"/>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="PASSWORD" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
            <TextBox PasswordChar="&#x25CF;" Text="{Binding ClearDbPassword}" Watermark="Enter your password"
                     MinHeight="44" FontSize="13" Background="#FFFFFF" Foreground="#111827"
                     BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="12,0" VerticalContentAlignment="Center"/>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="TYPE &quot;DELETE&quot; TO CONFIRM" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
            <TextBox Text="{Binding ClearDbVerification}" Watermark="DELETE"
                     MinHeight="44" FontSize="13" Background="#FFFFFF" Foreground="#111827"
                     BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="12,0" VerticalContentAlignment="Center"/>
          </StackPanel>

          <Button Command="{Binding ClearDatabaseCommand}" HorizontalAlignment="Right"
                  Background="#DC2626" Foreground="#FFFFFF" FontSize="13" FontWeight="SemiBold"
                  CornerRadius="8" Padding="18,9" Cursor="Hand" IsEnabled="{Binding !IsClearingDatabase}" BorderThickness="0">
            <TextBlock Text="Clear Database"/>
          </Button>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>

  <!-- Loading Overlay -->
  <Border IsVisible="{Binding IsBusy}" Background="#FFFFFF90" CornerRadius="12">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
      <ProgressBar IsIndeterminate="True" Width="120" Foreground="#202020" Background="#E5E7EB"/>
      <TextBlock Text="Saving..." FontSize="13" Foreground="#6B7280" HorizontalAlignment="Center"/>
    </StackPanel>
  </Border>

  <!-- Toast Notification -->
  <Border IsVisible="{Binding IsToastVisible}"
          HorizontalAlignment="Center" VerticalAlignment="Bottom"
          Margin="0,0,0,24" Padding="16,10" CornerRadius="10"
          Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1"
          BoxShadow="0 4 16 0 #40000000">
    <TextBlock Text="{Binding ToastMessage}" FontSize="13" Foreground="#111827"/>
  </Border>

  </Panel>
</UserControl>
