<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TrustSync.Desktop.ViewModels.Pages"
             x:Class="TrustSync.Desktop.Views.Pages.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <Panel>
  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="16" MaxWidth="600">

      <!-- Error -->
      <TextBlock Text="{Binding ErrorMessage}"
                 IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                 Foreground="{DynamicResource ErrorBrush}" FontSize="13" Margin="4,0"/>

      <!-- Profile Card -->
      <Border Background="{DynamicResource BackgroundPrimaryBrush}" CornerRadius="14" Padding="24,20"
              BoxShadow="0 1 4 0 #00000008">
        <StackPanel Spacing="16">
          <TextBlock Text="Profile" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
          <Grid ColumnDefinitions="Auto,*">
            <!-- Avatar preview -->
            <Panel Grid.Column="0" Width="72" Height="72" Margin="0,0,20,0">
              <!-- Fallback: initial circle -->
              <Border Width="72" Height="72" CornerRadius="36"
                      IsVisible="{Binding ProfileImagePath, Converter={x:Static StringConverters.IsNullOrEmpty}}">
                <Border.Background>
                  <DynamicResource ResourceKey="AvatarGradientBrush"/>
                </Border.Background>
                <TextBlock Text="?" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextOnAccentBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <!-- Image avatar -->
              <Border Width="72" Height="72" CornerRadius="36" ClipToBounds="True"
                      IsVisible="{Binding ProfileImagePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <Image Source="{Binding ProfileBitmap}" Stretch="UniformToFill"/>
              </Border>
            </Panel>
            <!-- Buttons -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8">
              <TextBlock Text="Profile Picture" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock Text="JPG, PNG or BMP. Recommended 200x200px." FontSize="11" Foreground="{DynamicResource TextLightBrush}"/>
              <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                <Button Click="OnPickProfileImage"
                        Background="{DynamicResource AccentPrimaryBrush}" Foreground="{DynamicResource TextOnAccentBrush}" FontSize="12" FontWeight="SemiBold"
                        CornerRadius="8" Padding="14,7" Cursor="Hand" BorderThickness="0">
                  <TextBlock Text="Upload Image"/>
                </Button>
                <Button Command="{Binding RemoveProfileImageCommand}"
                        IsVisible="{Binding ProfileImagePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Background="Transparent" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
                        Foreground="{DynamicResource TextMutedBrush}" FontSize="12" CornerRadius="8" Padding="14,7" Cursor="Hand">
                  <TextBlock Text="Remove"/>
                </Button>
              </StackPanel>
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- General Settings Card -->
      <Border Background="{DynamicResource BackgroundPrimaryBrush}" CornerRadius="14" Padding="24,20"
              BoxShadow="0 1 4 0 #00000008">
        <StackPanel Spacing="16">
          <TextBlock Text="General" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>

          <Grid ColumnDefinitions="*,200">
            <TextBlock Text="Display Name" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding UserDisplayName}" Watermark="Your name"
                     HorizontalAlignment="Stretch" MinHeight="44" FontSize="13" Background="{DynamicResource BackgroundPrimaryBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12,0" VerticalContentAlignment="Center"/>
          </Grid>

          <Grid ColumnDefinitions="*,200">
            <TextBlock Text="Default Currency" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" ItemsSource="{Binding Currencies}" SelectedItem="{Binding DefaultCurrency}"
                      HorizontalAlignment="Stretch" MinHeight="44" FontSize="13" Background="{DynamicResource BackgroundPrimaryBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                      BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8"/>
          </Grid>

          <Grid ColumnDefinitions="*,200">
            <TextBlock Text="Auto-Lock Timeout (minutes)" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" ItemsSource="{Binding TimeoutOptions}" SelectedItem="{Binding AutoLockTimeout}"
                      HorizontalAlignment="Stretch" MinHeight="44" FontSize="13" Background="{DynamicResource BackgroundPrimaryBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                      BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8"/>
          </Grid>

          <Grid ColumnDefinitions="*,200">
            <StackPanel Spacing="2">
              <TextBlock Text="Theme" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
              <TextBlock Text="Switch between light and dark mode" FontSize="11" Foreground="{DynamicResource TextLightBrush}"/>
            </StackPanel>
            <ComboBox Grid.Column="1" ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding ThemeMode}"
                      HorizontalAlignment="Stretch" MinHeight="44" FontSize="13"/>
          </Grid>

          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Spacing="2">
              <TextBlock Text="Start with Windows" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
              <TextBlock Text="Automatically launch TrustSync when you log in" FontSize="11" Foreground="{DynamicResource TextLightBrush}"/>
            </StackPanel>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoStartup}"
                          OnContent="" OffContent=""
                          VerticalAlignment="Center"/>
          </Grid>

          <Button Command="{Binding SaveSettingsCommand}" HorizontalAlignment="Right"
                  Background="{DynamicResource AccentPrimaryBrush}" Foreground="{DynamicResource TextOnAccentBrush}" FontSize="13" FontWeight="SemiBold"
                  CornerRadius="8" Padding="18,9" Cursor="Hand" IsEnabled="{Binding !IsBusy}" BorderThickness="0">
            <TextBlock Text="Save Settings"/>
          </Button>
        </StackPanel>
      </Border>

      <!-- Exchange Rates Card -->
      <Border Background="{DynamicResource BackgroundPrimaryBrush}" CornerRadius="14" Padding="24,20"
              BoxShadow="0 1 4 0 #00000008">
        <StackPanel Spacing="16">
          <TextBlock Text="Exchange Rates" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>

          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Spacing="4">
              <TextBlock Text="Last Updated" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
              <TextBlock Text="{Binding LastRateRefresh}" FontSize="13" Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>
            <Button Grid.Column="1" Command="{Binding RefreshRatesCommand}"
                    IsEnabled="{Binding !IsRefreshingRates}"
                    Background="{DynamicResource AccentPrimaryBrush}" Foreground="{DynamicResource TextOnAccentBrush}" FontSize="13" FontWeight="SemiBold"
                    CornerRadius="8" Padding="18,9" Cursor="Hand" BorderThickness="0" VerticalAlignment="Center">
              <TextBlock Text="Refresh Rates"/>
            </Button>
          </Grid>

          <TextBlock Text="Rates are fetched from Open ExchangeRate API (free, no key needed). They auto-refresh every 24 hours when you add a transaction."
                     FontSize="12" Foreground="{DynamicResource TextLightBrush}" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <!-- Change Password Card -->
      <Border Background="{DynamicResource BackgroundPrimaryBrush}" CornerRadius="14" Padding="24,20"
              BoxShadow="0 1 4 0 #00000008">
        <StackPanel Spacing="16">
          <TextBlock Text="Change Password" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>

          <StackPanel Spacing="6">
            <TextBlock Text="CURRENT PASSWORD" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}"/>
            <TextBox PasswordChar="&#x25CF;" Text="{Binding CurrentPassword}"/>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="NEW PASSWORD" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}"/>
            <TextBox PasswordChar="&#x25CF;" Text="{Binding NewPassword}"/>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="CONFIRM NEW PASSWORD" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}"/>
            <TextBox PasswordChar="&#x25CF;" Text="{Binding ConfirmNewPassword}"/>
          </StackPanel>

          <Button Command="{Binding ChangePasswordCommand}" HorizontalAlignment="Right"
                  Background="Transparent" BorderBrush="{DynamicResource ErrorBrush}" BorderThickness="1"
                  Foreground="{DynamicResource ErrorBrush}" FontSize="13" FontWeight="SemiBold"
                  CornerRadius="8" Padding="18,9" Cursor="Hand" IsEnabled="{Binding !IsBusy}">
            <TextBlock Text="Change Password"/>
          </Button>
        </StackPanel>
      </Border>

      <!-- Danger Zone Card -->
      <Border Background="{DynamicResource BackgroundPrimaryBrush}" CornerRadius="14" Padding="24,20"
              BoxShadow="0 1 4 0 #00000008" BorderBrush="{DynamicResource DangerBorderBrush}" BorderThickness="1">
        <StackPanel Spacing="16">
          <StackPanel Spacing="4">
            <TextBlock Text="Danger Zone" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource ErrorBrush}"/>
            <TextBlock Text="This action will permanently delete all your data (income, expenses, projects, companies, etc.). Your account and settings will be preserved."
                       FontSize="12" Foreground="{DynamicResource TextLightBrush}" TextWrapping="Wrap"/>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="PASSWORD" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}"/>
            <TextBox PasswordChar="&#x25CF;" Text="{Binding ClearDbPassword}" Watermark="Enter your password"
                     MinHeight="44" FontSize="13" Background="{DynamicResource BackgroundPrimaryBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12,0" VerticalContentAlignment="Center"/>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="TYPE &quot;DELETE&quot; TO CONFIRM" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}"/>
            <TextBox Text="{Binding ClearDbVerification}" Watermark="DELETE"
                     MinHeight="44" FontSize="13" Background="{DynamicResource BackgroundPrimaryBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12,0" VerticalContentAlignment="Center"/>
          </StackPanel>

          <Button Command="{Binding ClearDatabaseCommand}" HorizontalAlignment="Right"
                  Background="{DynamicResource ErrorBrush}" Foreground="{DynamicResource TextOnDangerBrush}" FontSize="13" FontWeight="SemiBold"
                  CornerRadius="8" Padding="18,9" Cursor="Hand" IsEnabled="{Binding !IsClearingDatabase}" BorderThickness="0">
            <TextBlock Text="Clear Database"/>
          </Button>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>

  <!-- Loading Overlay -->
  <Border IsVisible="{Binding IsBusy}" Background="{DynamicResource BackgroundOverlayBrush}" CornerRadius="12">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
      <ProgressBar IsIndeterminate="True" Width="120" Foreground="{DynamicResource AccentPrimaryBrush}" Background="{DynamicResource BorderDefaultBrush}"/>
      <TextBlock Text="Saving..." FontSize="13" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
    </StackPanel>
  </Border>

  <!-- Toast Notification -->
  <Border IsVisible="{Binding IsToastVisible}"
          HorizontalAlignment="Center" VerticalAlignment="Bottom"
          Margin="0,0,0,24" Padding="16,10" CornerRadius="10"
          Background="{DynamicResource BackgroundPrimaryBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
          BoxShadow="0 4 16 0 #40000000">
    <TextBlock Text="{Binding ToastMessage}" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
  </Border>

  </Panel>
</UserControl>
