<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TrustSync.Desktop.ViewModels.Pages"
             x:Class="TrustSync.Desktop.Views.Pages.ReportsView"
             x:DataType="vm:ReportsViewModel">

  <Panel>
  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="16">

      <!-- ROW 1: Controls Bar -->
      <Border Background="White" CornerRadius="14" Padding="20,16"
              BoxShadow="0 1 4 0 #00000008">
        <StackPanel Orientation="Horizontal" Spacing="12">
          <StackPanel Spacing="4">
            <TextBlock Text="YEAR" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
            <ComboBox ItemsSource="{Binding AvailableYears}" SelectedItem="{Binding SelectedYear}"
                      Width="100" Height="38" FontSize="13" Background="#FFFFFF" Foreground="#111827"
                      BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8"/>
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="MONTH" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
            <ComboBox ItemsSource="{Binding AvailableMonths}" SelectedItem="{Binding SelectedMonth}"
                      Width="80" Height="38" FontSize="13" Background="#FFFFFF" Foreground="#111827"
                      BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8"/>
          </StackPanel>
          <Button Command="{Binding ExportCsvCommand}" VerticalAlignment="Bottom"
                  Background="Transparent" BorderBrush="#E5E7EB" BorderThickness="1"
                  Foreground="#374151" FontSize="13" CornerRadius="8" Padding="18,9" Height="38" Cursor="Hand">
            <TextBlock Text="Export CSV"/>
          </Button>
          <Button Command="{Binding ExportPdfCommand}" VerticalAlignment="Bottom"
                  BorderThickness="0" CornerRadius="8" Padding="18,9" Height="38" Cursor="Hand">
            <Button.Background>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#202020" Offset="0"/>
                <GradientStop Color="#404040" Offset="1"/>
              </LinearGradientBrush>
            </Button.Background>
            <TextBlock Text="Export PDF" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
          </Button>
          <TextBlock Text="{Binding ErrorMessage}" VerticalAlignment="Bottom"
                     IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                     Foreground="#D97706" FontSize="12" Margin="12,0,0,8"/>
        </StackPanel>
      </Border>

      <!-- ROW 2: Monthly Summary -->
      <Border Background="White" CornerRadius="14" Padding="24,20"
              BoxShadow="0 1 4 0 #00000008">
        <StackPanel Spacing="12">
          <TextBlock Text="Monthly Summary" FontSize="16" FontWeight="SemiBold" Foreground="#111827"/>
          <!-- Header -->
          <Grid ColumnDefinitions="120,*,*,*,*,*">
            <TextBlock Grid.Column="0" Text="Month" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
            <TextBlock Grid.Column="1" Text="Income" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF" HorizontalAlignment="Right"/>
            <TextBlock Grid.Column="2" Text="Expenses" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF" HorizontalAlignment="Right"/>
            <TextBlock Grid.Column="3" Text="Deductions" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF" HorizontalAlignment="Right"/>
            <TextBlock Grid.Column="4" Text="Savings" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF" HorizontalAlignment="Right"/>
            <TextBlock Grid.Column="5" Text="Net" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF" HorizontalAlignment="Right"/>
          </Grid>
          <ItemsControl ItemsSource="{Binding MonthlySummaries}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Padding="0,8" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                  <Grid ColumnDefinitions="120,*,*,*,*,*">
                    <TextBlock Grid.Column="0" Text="{Binding MonthName}" FontSize="13" Foreground="#111827"/>
                    <TextBlock Grid.Column="1" FontSize="13" Foreground="#059669" HorizontalAlignment="Right">
                      <TextBlock.Text><MultiBinding StringFormat="{}{1}{0:N2}"><Binding Path="Income"/><Binding Path="$parent[ItemsControl].((vm:ReportsViewModel)DataContext).CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/></MultiBinding></TextBlock.Text>
                    </TextBlock>
                    <TextBlock Grid.Column="2" FontSize="13" Foreground="#DC2626" HorizontalAlignment="Right">
                      <TextBlock.Text><MultiBinding StringFormat="{}{1}{0:N2}"><Binding Path="Expenses"/><Binding Path="$parent[ItemsControl].((vm:ReportsViewModel)DataContext).CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/></MultiBinding></TextBlock.Text>
                    </TextBlock>
                    <TextBlock Grid.Column="3" FontSize="13" Foreground="#D97706" HorizontalAlignment="Right">
                      <TextBlock.Text><MultiBinding StringFormat="{}{1}{0:N2}"><Binding Path="Deductions"/><Binding Path="$parent[ItemsControl].((vm:ReportsViewModel)DataContext).CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/></MultiBinding></TextBlock.Text>
                    </TextBlock>
                    <TextBlock Grid.Column="4" FontSize="13" Foreground="#202020" HorizontalAlignment="Right">
                      <TextBlock.Text><MultiBinding StringFormat="{}{1}{0:N2}"><Binding Path="Savings"/><Binding Path="$parent[ItemsControl].((vm:ReportsViewModel)DataContext).CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/></MultiBinding></TextBlock.Text>
                    </TextBlock>
                    <TextBlock Grid.Column="5" FontSize="13" FontWeight="SemiBold" Foreground="#111827" HorizontalAlignment="Right">
                      <TextBlock.Text><MultiBinding StringFormat="{}{1}{0:N2}"><Binding Path="Net"/><Binding Path="$parent[ItemsControl].((vm:ReportsViewModel)DataContext).CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/></MultiBinding></TextBlock.Text>
                    </TextBlock>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- ROW 3: Income by Source + Expense by Category -->
      <Grid ColumnDefinitions="*,16,*">
        <Border Grid.Column="0" Background="White" CornerRadius="14" Padding="24,20"
                BoxShadow="0 1 4 0 #00000008">
          <StackPanel Spacing="12">
            <TextBlock Text="Income by Source" FontSize="16" FontWeight="SemiBold" Foreground="#111827"/>
            <ItemsControl ItemsSource="{Binding IncomeBySource}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Padding="0,8" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto,50">
                      <TextBlock Grid.Column="0" Text="{Binding Source}" FontSize="13" Foreground="#374151"/>
                      <TextBlock Grid.Column="1" FontSize="13" Foreground="#059669" Margin="12,0">
                        <TextBlock.Text><MultiBinding StringFormat="{}{1}{0:N2}"><Binding Path="Amount"/><Binding Path="$parent[ItemsControl].((vm:ReportsViewModel)DataContext).CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/></MultiBinding></TextBlock.Text>
                      </TextBlock>
                      <Border Grid.Column="2" Background="#F3F4F6" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding Percentage, StringFormat={}{0:F0}%}" FontSize="10" Foreground="#6B7280"/>
                      </Border>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="No income data" IsVisible="{Binding !IncomeBySource.Count}" FontSize="13" Foreground="#9CA3AF"/>
          </StackPanel>
        </Border>

        <Border Grid.Column="2" Background="White" CornerRadius="14" Padding="24,20"
                BoxShadow="0 1 4 0 #00000008">
          <StackPanel Spacing="12">
            <TextBlock Text="Expense by Category" FontSize="16" FontWeight="SemiBold" Foreground="#111827"/>
            <ItemsControl ItemsSource="{Binding ExpenseByCategory}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Padding="0,8" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                      <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4" Background="{Binding ColorHex}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="1" Text="{Binding Category}" FontSize="13" Foreground="#374151"/>
                      <TextBlock Grid.Column="2" FontSize="13" Foreground="#DC2626" Margin="12,0">
                        <TextBlock.Text><MultiBinding StringFormat="{}{1}{0:N2}"><Binding Path="Amount"/><Binding Path="$parent[ItemsControl].((vm:ReportsViewModel)DataContext).CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/></MultiBinding></TextBlock.Text>
                      </TextBlock>
                      <Border Grid.Column="3" Background="#F3F4F6" CornerRadius="4" Padding="6,2">
                        <TextBlock Text="{Binding Percentage, StringFormat={}{0:F0}%}" FontSize="10" Foreground="#6B7280"/>
                      </Border>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="No expense data" IsVisible="{Binding !ExpenseByCategory.Count}" FontSize="13" Foreground="#9CA3AF"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- ROW 4: Project Profitability -->
      <Border Background="White" CornerRadius="14" Padding="24,20"
              BoxShadow="0 1 4 0 #00000008">
        <StackPanel Spacing="12">
          <TextBlock Text="Project Profitability" FontSize="16" FontWeight="SemiBold" Foreground="#111827"/>
          <Grid ColumnDefinitions="*,120,120,120,120,80">
            <TextBlock Grid.Column="0" Text="Project" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
            <TextBlock Grid.Column="1" Text="Agreed" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF" HorizontalAlignment="Right"/>
            <TextBlock Grid.Column="2" Text="Received" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF" HorizontalAlignment="Right"/>
            <TextBlock Grid.Column="3" Text="Expenses" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF" HorizontalAlignment="Right"/>
            <TextBlock Grid.Column="4" Text="Profit" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF" HorizontalAlignment="Right"/>
            <TextBlock Grid.Column="5" Text="Margin" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF" HorizontalAlignment="Right"/>
          </Grid>
          <ItemsControl ItemsSource="{Binding ProjectProfitability}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Padding="0,8" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                  <Grid ColumnDefinitions="*,120,120,120,120,80">
                    <StackPanel Grid.Column="0" Spacing="1">
                      <TextBlock Text="{Binding ProjectName}" FontSize="13" Foreground="#111827"/>
                      <TextBlock Text="{Binding CompanyName}" FontSize="11" Foreground="#9CA3AF"
                                 IsVisible="{Binding CompanyName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" FontSize="13" Foreground="#374151" HorizontalAlignment="Right">
                      <TextBlock.Text><MultiBinding StringFormat="{}{1}{0:N2}"><Binding Path="AgreedAmount"/><Binding Path="$parent[ItemsControl].((vm:ReportsViewModel)DataContext).CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/></MultiBinding></TextBlock.Text>
                    </TextBlock>
                    <TextBlock Grid.Column="2" FontSize="13" Foreground="#059669" HorizontalAlignment="Right">
                      <TextBlock.Text><MultiBinding StringFormat="{}{1}{0:N2}"><Binding Path="ReceivedAmount"/><Binding Path="$parent[ItemsControl].((vm:ReportsViewModel)DataContext).CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/></MultiBinding></TextBlock.Text>
                    </TextBlock>
                    <TextBlock Grid.Column="3" FontSize="13" Foreground="#DC2626" HorizontalAlignment="Right">
                      <TextBlock.Text><MultiBinding StringFormat="{}{1}{0:N2}"><Binding Path="TotalExpenses"/><Binding Path="$parent[ItemsControl].((vm:ReportsViewModel)DataContext).CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/></MultiBinding></TextBlock.Text>
                    </TextBlock>
                    <TextBlock Grid.Column="4" FontSize="13" FontWeight="SemiBold" Foreground="#111827" HorizontalAlignment="Right">
                      <TextBlock.Text><MultiBinding StringFormat="{}{1}{0:N2}"><Binding Path="Profit"/><Binding Path="$parent[ItemsControl].((vm:ReportsViewModel)DataContext).CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/></MultiBinding></TextBlock.Text>
                    </TextBlock>
                    <Border Grid.Column="5" Background="#F3F4F6" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Center">
                      <TextBlock Text="{Binding ProfitMargin, StringFormat={}{0:F0}%}" FontSize="10" Foreground="#6B7280"/>
                    </Border>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock Text="No projects" IsVisible="{Binding !ProjectProfitability.Count}" FontSize="13" Foreground="#9CA3AF"/>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>

  <!-- Loading Overlay -->
  <Border IsVisible="{Binding IsBusy}" Background="#FFFFFF90" CornerRadius="12">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
      <ProgressBar IsIndeterminate="True" Width="120" Foreground="#202020" Background="#E5E7EB"/>
      <TextBlock Text="Loading..." FontSize="13" Foreground="#6B7280" HorizontalAlignment="Center"/>
    </StackPanel>
  </Border>

  </Panel>
</UserControl>
