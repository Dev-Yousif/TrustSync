<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TrustSync.Desktop.ViewModels.Pages"
             x:Class="TrustSync.Desktop.Views.Pages.ReportsView"
             x:DataType="vm:ReportsViewModel">

  <Panel>
  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="16">

      <!-- ROW 1: Controls Bar -->
      <Border Background="{DynamicResource BackgroundPrimaryBrush}" CornerRadius="14" Padding="20,16"
              BoxShadow="0 1 4 0 #00000008">
        <StackPanel Orientation="Horizontal" Spacing="12">
          <StackPanel Spacing="4">
            <TextBlock Text="YEAR" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}"/>
            <ComboBox ItemsSource="{Binding AvailableYears}" SelectedItem="{Binding SelectedYear}"
                      Width="100" Height="38" FontSize="13" Background="{DynamicResource BackgroundPrimaryBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                      BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8"/>
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="MONTH" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}"/>
            <ComboBox ItemsSource="{Binding AvailableMonths}" SelectedItem="{Binding SelectedMonth}"
                      Width="80" Height="38" FontSize="13" Background="{DynamicResource BackgroundPrimaryBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                      BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8"/>
          </StackPanel>
          <Button Command="{Binding ExportCsvCommand}" VerticalAlignment="Bottom"
                  Background="Transparent" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
                  Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" CornerRadius="8" Padding="18,9" Height="38" Cursor="Hand">
            <TextBlock Text="Export CSV"/>
          </Button>
          <Button Command="{Binding ExportPdfCommand}" VerticalAlignment="Bottom"
                  BorderThickness="0" CornerRadius="8" Padding="18,9" Height="38" Cursor="Hand">
            <Button.Background>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#202020" Offset="0"/>
                <GradientStop Color="#404040" Offset="1"/>
              </LinearGradientBrush>
            </Button.Background>
            <TextBlock Text="Export PDF" Foreground="{DynamicResource TextOnAccentBrush}" FontSize="13" FontWeight="SemiBold"/>
          </Button>
          <TextBlock Text="{Binding ErrorMessage}" VerticalAlignment="Bottom"
                     IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                     Foreground="{DynamicResource WarningBrush}" FontSize="12" Margin="12,0,0,8"/>
        </StackPanel>
      </Border>

      <!-- ROW 2: Monthly Summary -->
      <Border Background="{DynamicResource BackgroundPrimaryBrush}" CornerRadius="14" Padding="24,20"
              BoxShadow="0 1 4 0 #00000008">
        <StackPanel Spacing="12">
          <TextBlock Text="Monthly Summary" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
          <!-- Header -->
          <Grid ColumnDefinitions="120,*,*,*,*,*">
            <TextBlock Grid.Column="0" Text="Month" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}"/>
            <TextBlock Grid.Column="1" Text="Income" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Right"/>
            <TextBlock Grid.Column="2" Text="Expenses" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Right"/>
            <TextBlock Grid.Column="3" Text="Deductions" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Right"/>
            <TextBlock Grid.Column="4" Text="Savings" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Right"/>
            <TextBlock Grid.Column="5" Text="Net" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Right"/>
          </Grid>
          <ItemsControl ItemsSource="{Binding MonthlySummaries}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Padding="0,8" BorderBrush="{DynamicResource BackgroundHoverBrush}" BorderThickness="0,0,0,1">
                  <Grid ColumnDefinitions="120,*,*,*,*,*">
                    <TextBlock Grid.Column="0" Text="{Binding MonthName}" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Grid.Column="1" FontSize="13" Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Right">
                      <TextBlock.Text><MultiBinding StringFormat="{}{1}{0:N2}"><Binding Path="Income"/><Binding Path="$parent[ItemsControl].((vm:ReportsViewModel)DataContext).CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/></MultiBinding></TextBlock.Text>
                    </TextBlock>
                    <TextBlock Grid.Column="2" FontSize="13" Foreground="{DynamicResource ErrorBrush}" HorizontalAlignment="Right">
                      <TextBlock.Text><MultiBinding StringFormat="{}{1}{0:N2}"><Binding Path="Expenses"/><Binding Path="$parent[ItemsControl].((vm:ReportsViewModel)DataContext).CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/></MultiBinding></TextBlock.Text>
                    </TextBlock>
                    <TextBlock Grid.Column="3" FontSize="13" Foreground="{DynamicResource WarningBrush}" HorizontalAlignment="Right">
                      <TextBlock.Text><MultiBinding StringFormat="{}{1}{0:N2}"><Binding Path="Deductions"/><Binding Path="$parent[ItemsControl].((vm:ReportsViewModel)DataContext).CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/></MultiBinding></TextBlock.Text>
                    </TextBlock>
                    <TextBlock Grid.Column="4" FontSize="13" Foreground="{DynamicResource AccentPrimaryBrush}" HorizontalAlignment="Right">
                      <TextBlock.Text><MultiBinding StringFormat="{}{1}{0:N2}"><Binding Path="Savings"/><Binding Path="$parent[ItemsControl].((vm:ReportsViewModel)DataContext).CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/></MultiBinding></TextBlock.Text>
                    </TextBlock>
                    <TextBlock Grid.Column="5" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right">
                      <TextBlock.Text><MultiBinding StringFormat="{}{1}{0:N2}"><Binding Path="Net"/><Binding Path="$parent[ItemsControl].((vm:ReportsViewModel)DataContext).CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/></MultiBinding></TextBlock.Text>
                    </TextBlock>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- ROW 3: Income by Source + Expense by Category -->
      <Grid ColumnDefinitions="*,16,*">
        <Border Grid.Column="0" Background="{DynamicResource BackgroundPrimaryBrush}" CornerRadius="14" Padding="24,20"
                BoxShadow="0 1 4 0 #00000008">
          <StackPanel Spacing="12">
            <TextBlock Text="Income by Source" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <ItemsControl ItemsSource="{Binding IncomeBySource}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Padding="0,8" BorderBrush="{DynamicResource BackgroundHoverBrush}" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto,50">
                      <TextBlock Grid.Column="0" Text="{Binding Source}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" FontSize="13" Foreground="{DynamicResource SuccessBrush}" Margin="12,0">
                        <TextBlock.Text><MultiBinding StringFormat="{}{1}{0:N2}"><Binding Path="Amount"/><Binding Path="$parent[ItemsControl].((vm:ReportsViewModel)DataContext).CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/></MultiBinding></TextBlock.Text>
                      </TextBlock>
                      <Border Grid.Column="2" Background="{DynamicResource BackgroundHoverBrush}" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding Percentage, StringFormat={}{0:F0}%}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                      </Border>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="No income data" IsVisible="{Binding !IncomeBySource.Count}" FontSize="13" Foreground="{DynamicResource TextLightBrush}"/>
          </StackPanel>
        </Border>

        <Border Grid.Column="2" Background="{DynamicResource BackgroundPrimaryBrush}" CornerRadius="14" Padding="24,20"
                BoxShadow="0 1 4 0 #00000008">
          <StackPanel Spacing="12">
            <TextBlock Text="Expense by Category" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <ItemsControl ItemsSource="{Binding ExpenseByCategory}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Padding="0,8" BorderBrush="{DynamicResource BackgroundHoverBrush}" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                      <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4" Background="{Binding ColorHex}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="1" Text="{Binding Category}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="2" FontSize="13" Foreground="{DynamicResource ErrorBrush}" Margin="12,0">
                        <TextBlock.Text><MultiBinding StringFormat="{}{1}{0:N2}"><Binding Path="Amount"/><Binding Path="$parent[ItemsControl].((vm:ReportsViewModel)DataContext).CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/></MultiBinding></TextBlock.Text>
                      </TextBlock>
                      <Border Grid.Column="3" Background="{DynamicResource BackgroundHoverBrush}" CornerRadius="4" Padding="6,2">
                        <TextBlock Text="{Binding Percentage, StringFormat={}{0:F0}%}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                      </Border>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="No expense data" IsVisible="{Binding !ExpenseByCategory.Count}" FontSize="13" Foreground="{DynamicResource TextLightBrush}"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- ROW 4: Project Profitability -->
      <Border Background="{DynamicResource BackgroundPrimaryBrush}" CornerRadius="14" Padding="24,20"
              BoxShadow="0 1 4 0 #00000008">
        <StackPanel Spacing="12">
          <TextBlock Text="Project Profitability" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
          <Grid ColumnDefinitions="*,120,120,120,120,80">
            <TextBlock Grid.Column="0" Text="Project" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}"/>
            <TextBlock Grid.Column="1" Text="Agreed" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Right"/>
            <TextBlock Grid.Column="2" Text="Received" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Right"/>
            <TextBlock Grid.Column="3" Text="Expenses" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Right"/>
            <TextBlock Grid.Column="4" Text="Profit" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Right"/>
            <TextBlock Grid.Column="5" Text="Margin" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Right"/>
          </Grid>
          <ItemsControl ItemsSource="{Binding ProjectProfitability}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Padding="0,8" BorderBrush="{DynamicResource BackgroundHoverBrush}" BorderThickness="0,0,0,1">
                  <Grid ColumnDefinitions="*,120,120,120,120,80">
                    <StackPanel Grid.Column="0" Spacing="1">
                      <TextBlock Text="{Binding ProjectName}" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                      <TextBlock Text="{Binding CompanyName}" FontSize="11" Foreground="{DynamicResource TextLightBrush}"
                                 IsVisible="{Binding CompanyName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right">
                      <TextBlock.Text><MultiBinding StringFormat="{}{1}{0:N2}"><Binding Path="AgreedAmount"/><Binding Path="$parent[ItemsControl].((vm:ReportsViewModel)DataContext).CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/></MultiBinding></TextBlock.Text>
                    </TextBlock>
                    <TextBlock Grid.Column="2" FontSize="13" Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Right">
                      <TextBlock.Text><MultiBinding StringFormat="{}{1}{0:N2}"><Binding Path="ReceivedAmount"/><Binding Path="$parent[ItemsControl].((vm:ReportsViewModel)DataContext).CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/></MultiBinding></TextBlock.Text>
                    </TextBlock>
                    <TextBlock Grid.Column="3" FontSize="13" Foreground="{DynamicResource ErrorBrush}" HorizontalAlignment="Right">
                      <TextBlock.Text><MultiBinding StringFormat="{}{1}{0:N2}"><Binding Path="TotalExpenses"/><Binding Path="$parent[ItemsControl].((vm:ReportsViewModel)DataContext).CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/></MultiBinding></TextBlock.Text>
                    </TextBlock>
                    <TextBlock Grid.Column="4" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right">
                      <TextBlock.Text><MultiBinding StringFormat="{}{1}{0:N2}"><Binding Path="Profit"/><Binding Path="$parent[ItemsControl].((vm:ReportsViewModel)DataContext).CurrencyCode" Converter="{StaticResource CurrencySymbolConverter}"/></MultiBinding></TextBlock.Text>
                    </TextBlock>
                    <Border Grid.Column="5" Background="{DynamicResource BackgroundHoverBrush}" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Center">
                      <TextBlock Text="{Binding ProfitMargin, StringFormat={}{0:F0}%}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                    </Border>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock Text="No projects" IsVisible="{Binding !ProjectProfitability.Count}" FontSize="13" Foreground="{DynamicResource TextLightBrush}"/>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>

  <!-- Loading Overlay -->
  <Border IsVisible="{Binding IsBusy}" Background="{DynamicResource BackgroundOverlayBrush}" CornerRadius="12">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
      <ProgressBar IsIndeterminate="True" Width="120" Foreground="{DynamicResource AccentPrimaryBrush}" Background="{DynamicResource BorderDefaultBrush}"/>
      <TextBlock Text="Loading..." FontSize="13" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
    </StackPanel>
  </Border>

  </Panel>
</UserControl>
