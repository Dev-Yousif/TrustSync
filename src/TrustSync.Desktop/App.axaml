<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:TrustSync.Desktop.Converters"
             x:Class="TrustSync.Desktop.App"
             RequestedThemeVariant="Light">
  <Application.Styles>
    <FluentTheme />

    <!-- Global TextBox styling -->
    <Style Selector="TextBox">
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="MinHeight" Value="40"/>
      <Setter Property="Padding" Value="12,0"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="CaretBrush" Value="#202020"/>
      <Setter Property="SelectionBrush" Value="#20202040"/>
    </Style>

    <!-- Global ComboBox styling -->
    <Style Selector="ComboBox">
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="MinHeight" Value="40"/>
      <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- ComboBox dropdown popup container -->
    <Style Selector="ComboBox /template/ Popup">
      <Setter Property="VerticalOffset" Value="4"/>
    </Style>
    <!-- Target popup border by multiple selectors to ensure it hits -->
    <Style Selector="ComboBox /template/ Popup Border">
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="BorderBrush" Value="#E5E7EB"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Background" Value="#FFFFFF"/>
      <Setter Property="BoxShadow" Value="0 8 24 0 #25000000"/>
      <Setter Property="Padding" Value="4"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>
    <Style Selector="ComboBox /template/ Border#PopupBorder">
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="BorderBrush" Value="#E5E7EB"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Background" Value="#FFFFFF"/>
      <Setter Property="BoxShadow" Value="0 8 24 0 #25000000"/>
      <Setter Property="Padding" Value="4"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <!-- ComboBox dropdown items -->
    <Style Selector="ComboBoxItem">
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="10,7"/>
      <Setter Property="Margin" Value="2"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Foreground" Value="#111827"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="MinHeight" Value="0"/>
    </Style>
    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#F3F4F6"/>
      <Setter Property="Foreground" Value="#111827"/>
    </Style>
    <Style Selector="ComboBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#F3F4F6"/>
      <Setter Property="Foreground" Value="#111827"/>
    </Style>
    <Style Selector="ComboBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#E5E7EB"/>
      <Setter Property="Foreground" Value="#111827"/>
    </Style>
    <Style Selector="ComboBoxItem:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#E5E7EB"/>
      <Setter Property="Foreground" Value="#111827"/>
    </Style>
    <!-- Hide the selection pill indicator -->
    <Style Selector="ComboBoxItem /template/ Rectangle#SelectionIndicator">
      <Setter Property="IsVisible" Value="False"/>
    </Style>

    <!-- DatePicker styling -->
    <Style Selector="DatePicker">
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="MinHeight" Value="40"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Foreground" Value="#111827"/>
      <Setter Property="Background" Value="#FFFFFF"/>
      <Setter Property="BorderBrush" Value="#D1D5DB"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
    <!-- Border styling and hover/focus states -->
    <Style Selector="DatePicker /template/ Border#PART_BorderElement">
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Background" Value="#FFFFFF"/>
      <Setter Property="BorderBrush" Value="#D1D5DB"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="DatePicker:pointerover /template/ Border#PART_BorderElement">
      <Setter Property="BorderBrush" Value="#9CA3AF"/>
    </Style>
    <Style Selector="DatePicker:focus-within /template/ Border#PART_BorderElement">
      <Setter Property="BorderBrush" Value="#202020"/>
    </Style>
    <!-- The main flyout button — stretch to fill, transparent bg -->
    <Style Selector="DatePicker /template/ Button#PART_FlyoutButton">
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>
    <!-- Thin subtle separators between segments -->
    <Style Selector="DatePicker /template/ Rectangle#PART_FirstSpacer">
      <Setter Property="Fill" Value="#E5E7EB"/>
      <Setter Property="Width" Value="1"/>
    </Style>
    <Style Selector="DatePicker /template/ Rectangle#PART_SecondSpacer">
      <Setter Property="Fill" Value="#E5E7EB"/>
      <Setter Property="Width" Value="1"/>
    </Style>
    <!-- Style the day/month/year text -->
    <Style Selector="DatePicker /template/ TextBlock#PART_DayTextBlock">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Foreground" Value="#111827"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="DatePicker /template/ TextBlock#PART_MonthTextBlock">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Foreground" Value="#111827"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="TextAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="DatePicker /template/ TextBlock#PART_YearTextBlock">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Foreground" Value="#111827"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Disable Fluent theme hover/pressed color change on all buttons -->
    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"/>
      <Setter Property="BorderBrush" Value="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}"/>
    </Style>
    <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"/>
      <Setter Property="BorderBrush" Value="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}"/>
    </Style>

    <!-- ScrollBar: thicker thumb, rounded -->
    <Style Selector="ScrollBar:vertical /template/ Thumb">
      <Setter Property="MinWidth" Value="10"/>
      <Setter Property="Width" Value="10"/>
    </Style>
    <Style Selector="ScrollBar:vertical">
      <Setter Property="Width" Value="14"/>
    </Style>

  </Application.Styles>
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="/Themes/ThemeLight.axaml"/>
      </ResourceDictionary.MergedDictionaries>
      <conv:CurrencySymbolConverter x:Key="CurrencySymbolConverter"/>
      <conv:ReminderScheduleConverter x:Key="ReminderScheduleConverter"/>
      <conv:ReminderNextFireConverter x:Key="ReminderNextFireConverter"/>
      <conv:ReminderEnabledOpacityConverter x:Key="ReminderEnabledOpacityConverter"/>
    </ResourceDictionary>
  </Application.Resources>
</Application>
