<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:YousifAccounting.Desktop.ViewModels.Pages"
             x:Class="YousifAccounting.Desktop.Views.Pages.SavingsView"
             x:DataType="vm:SavingsViewModel">

  <Panel>
  <Panel Classes.dialog="{Binding IsConfirmDialogOpen}" Classes.goalEditor="{Binding IsGoalEditorOpen}" Classes.entryEditor="{Binding IsEntryEditorOpen}">
    <Panel.Styles>
      <Style Selector="Panel.dialog">
        <Setter Property="Effect"><Setter.Value><BlurEffect Radius="6"/></Setter.Value></Setter>
      </Style>
      <Style Selector="Panel.goalEditor">
        <Setter Property="Effect"><Setter.Value><BlurEffect Radius="6"/></Setter.Value></Setter>
      </Style>
      <Style Selector="Panel.entryEditor">
        <Setter Property="Effect"><Setter.Value><BlurEffect Radius="6"/></Setter.Value></Setter>
      </Style>
    </Panel.Styles>
  <Grid ColumnDefinitions="*,380">

    <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Disabled">
      <StackPanel Spacing="16" Margin="0,0,16,0">

        <Border Background="White" CornerRadius="14" Padding="20,16" BoxShadow="0 1 4 0 #00000008">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Saving Goals" FontSize="16" FontWeight="SemiBold" Foreground="#111827" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Command="{Binding OpenCreateGoalCommand}"
                    Theme="{StaticResource BtnPrimary}" CornerRadius="8" Padding="18,9">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="+" FontSize="16" FontWeight="Bold" Margin="0,-2,0,0"/>
                <TextBlock Text="New Goal"/>
              </StackPanel>
            </Button>
          </Grid>
        </Border>

        <Border Background="White" CornerRadius="14" Padding="24,20" BoxShadow="0 1 4 0 #00000008">
          <StackPanel Spacing="4">
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
              <TextBlock Text="All Goals" FontSize="16" FontWeight="SemiBold" Foreground="#111827"/>
              <Border Grid.Column="1" Background="#F9FAFB" CornerRadius="6" Padding="10,4">
                <TextBlock Text="{Binding Goals.Count, StringFormat={}{0} goals}" FontSize="11" Foreground="#6B7280" FontWeight="Medium"/>
              </Border>
            </Grid>

            <ItemsControl ItemsSource="{Binding Goals}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Command="{Binding $parent[ItemsControl].((vm:SavingsViewModel)DataContext).SelectGoalCommand}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="0" Margin="0" Cursor="Hand">
                    <Border Padding="12,14" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                      <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                          <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Width="38" Height="38" CornerRadius="10" Background="#F5F5F5" VerticalAlignment="Center">
                              <Path Data="{StaticResource IconSavings}" Stroke="#202020" StrokeThickness="1.8" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding Name}" FontSize="13.5" FontWeight="SemiBold" Foreground="#111827" VerticalAlignment="Center"/>
                          </StackPanel>
                          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                            <Button Command="{Binding $parent[ItemsControl].((vm:SavingsViewModel)DataContext).OpenEditGoalCommand}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Padding="8,5" CornerRadius="6" Cursor="Hand">
                              <TextBlock Text="Edit" FontSize="11" Foreground="#374151" FontWeight="Medium"/>
                            </Button>
                            <Button Command="{Binding $parent[ItemsControl].((vm:SavingsViewModel)DataContext).RequestDeleteGoalCommand}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Padding="8,5" CornerRadius="6" Cursor="Hand">
                              <TextBlock Text="Del" FontSize="11" Foreground="#DC2626" FontWeight="Medium"/>
                            </Button>
                          </StackPanel>
                        </Grid>
                        <Grid Height="6">
                          <Border Background="#F3F4F6" CornerRadius="3"/>
                          <Border Background="#202020" CornerRadius="3" HorizontalAlignment="Left" Width="200"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                          <TextBlock FontSize="12" Foreground="#9CA3AF">
                            <TextBlock.Text>
                              <MultiBinding StringFormat="{}{0:N2} / {1:N2}">
                                <Binding Path="SavedAmount"/>
                                <Binding Path="TargetAmount"/>
                              </MultiBinding>
                            </TextBlock.Text>
                          </TextBlock>
                          <TextBlock Grid.Column="1" Text="{Binding ProgressPercentage, StringFormat={}{0:F0}%}" FontSize="12" FontWeight="SemiBold" Foreground="#202020"/>
                        </Grid>
                      </StackPanel>
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel IsVisible="{Binding !Goals.Count}" HorizontalAlignment="Center" Margin="0,40" Spacing="10">
              <Border Width="48" Height="48" CornerRadius="12" Background="#F3F4F6" HorizontalAlignment="Center">
                <Path Data="{StaticResource IconSavings}" Stroke="#9CA3AF" StrokeThickness="1.8" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock Text="No saving goals" FontSize="16" FontWeight="SemiBold" Foreground="#111827" HorizontalAlignment="Center"/>
              <TextBlock Text="Create a goal and track your savings progress." FontSize="13" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
              <Button Command="{Binding OpenCreateGoalCommand}"
                      Theme="{StaticResource BtnPrimary}" CornerRadius="8" Padding="18,9"
                      HorizontalAlignment="Center" Margin="0,8,0,0">
                <TextBlock Text="+ New Goal"/>
              </Button>
            </StackPanel>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <!-- Entries Panel -->
    <Border Grid.Column="1" Background="White" CornerRadius="14" BoxShadow="0 1 4 0 #00000008">
      <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Padding="20,16" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Entries" FontSize="16" FontWeight="SemiBold" Foreground="#111827" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Command="{Binding OpenAddEntryCommand}" IsVisible="{Binding SelectedGoal, Converter={x:Static ObjectConverters.IsNotNull}}"
                    Theme="{StaticResource BtnPrimary}" FontSize="12" CornerRadius="8" Padding="14,7">
              <TextBlock Text="+ Add"/>
            </Button>
          </Grid>
        </Border>
        <Panel Grid.Row="1">
          <ScrollViewer IsVisible="{Binding Entries.Count}" Padding="20,8,20,20">
            <ItemsControl ItemsSource="{Binding Entries}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Padding="0,10" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                      <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="{Binding Amount, StringFormat={}{0:N2}}" FontSize="14" FontWeight="SemiBold" Foreground="#059669"/>
                        <TextBlock Text="{Binding Date, StringFormat={}{0:MMM dd}}" FontSize="11" Foreground="#9CA3AF"/>
                      </StackPanel>
                      <TextBlock Grid.Column="1" Text="{Binding Notes}" FontSize="11" Foreground="#9CA3AF" VerticalAlignment="Center" Margin="8,0" IsVisible="{Binding Notes, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                      <Button Grid.Column="2" Command="{Binding $parent[ItemsControl].((vm:SavingsViewModel)DataContext).RequestDeleteEntryCommand}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Padding="6,4" CornerRadius="6" Cursor="Hand" VerticalAlignment="Center">
                        <TextBlock Text="x" FontSize="11" Foreground="#DC2626"/>
                      </Button>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
          <TextBlock IsVisible="{Binding !Entries.Count}" Text="Select a goal to view entries." FontSize="13" Foreground="#9CA3AF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Panel>
      </Grid>
    </Border>

  </Grid>

  <Border IsVisible="{Binding IsBusy}" Background="#FFFFFF90" CornerRadius="12">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
      <ProgressBar IsIndeterminate="True" Width="120" Foreground="#202020" Background="#E5E7EB"/>
      <TextBlock Text="Loading..." FontSize="13" Foreground="#6B7280" HorizontalAlignment="Center"/>
    </StackPanel>
  </Border>
  </Panel>

  <!-- Confirm Dialog -->
  <Border IsVisible="{Binding IsConfirmDialogOpen}" Background="#00000050" CornerRadius="12">
    <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="400" Background="#FFFFFF" CornerRadius="16" BorderBrush="#E5E7EB" BorderThickness="1" BoxShadow="0 24 48 0 #30000000" ClipToBounds="True">
      <StackPanel>
        <StackPanel Margin="32,32,32,0" Spacing="14" HorizontalAlignment="Center">
          <Border Width="56" Height="56" CornerRadius="28" Background="#FEF2F2" HorizontalAlignment="Center">
            <Border Width="36" Height="36" CornerRadius="18" Background="#FEE2E2" HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock Text="!" FontSize="22" FontWeight="Bold" Foreground="#DC2626" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </Border>
          <TextBlock Text="{Binding ConfirmDialogTitle}" FontSize="17" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Center" TextAlignment="Center"/>
          <TextBlock Text="{Binding ConfirmDialogMessage}" FontSize="13" Foreground="#6B7280" TextWrapping="Wrap" TextAlignment="Center" LineHeight="20" Margin="0,0,0,4"/>
        </StackPanel>
        <Border Margin="0,24,0,0" Padding="24,18" BorderBrush="#F3F4F6" BorderThickness="0,1,0,0" Background="#FAFBFC">
          <Grid ColumnDefinitions="*,10,*">
            <Button Grid.Column="0" Command="{Binding ConfirmDialogNoCommand}"
                    Theme="{StaticResource BtnSecondary}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="42">
              <TextBlock Text="Cancel"/>
            </Button>
            <Button Grid.Column="2" Command="{Binding ConfirmDialogYesCommand}"
                    Theme="{StaticResource BtnDanger}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="42">
              <TextBlock Text="Delete"/>
            </Button>
          </Grid>
        </Border>
      </StackPanel>
    </Border>
  </Border>

  <!-- Goal Editor -->
  <Border IsVisible="{Binding IsGoalEditorOpen}" Background="#00000050" CornerRadius="12">
    <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="460" Background="#FFFFFF" CornerRadius="16" BorderBrush="#E5E7EB" BorderThickness="1" BoxShadow="0 24 48 0 #30000000" ClipToBounds="True">
      <StackPanel>
        <Grid ColumnDefinitions="Auto,*,Auto" Margin="28,24,20,0">
          <Border Width="42" Height="42" CornerRadius="12" Background="#F5F5F5">
            <Path Data="{StaticResource IconSavings}" Stroke="#202020" StrokeThickness="1.8" Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center" Spacing="2">
            <TextBlock Text="Saving Goal" FontSize="17" FontWeight="Bold" Foreground="#111827"/>
            <TextBlock Text="Set your savings target" FontSize="12" Foreground="#9CA3AF"/>
          </StackPanel>
          <Button Grid.Column="2" Command="{Binding CloseGoalEditorCommand}" Background="Transparent" BorderThickness="0" Padding="10" CornerRadius="8" Cursor="Hand" VerticalAlignment="Top">
            <TextBlock Text="✕" FontSize="16" Foreground="#9CA3AF"/>
          </Button>
        </Grid>
        <Border Height="1" Background="#F3F4F6" Margin="0,20,0,0"/>

        <StackPanel Margin="28,20,28,8" Spacing="16">
          <StackPanel Spacing="6">
            <TextBlock Text="NAME" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
            <TextBox Text="{Binding EditorGoalName}"/>
            <TextBlock Text="{Binding GoalNameError}" FontSize="11" Foreground="#DC2626" IsVisible="{Binding HasGoalNameError}"/>
          </StackPanel>
          <Grid ColumnDefinitions="*,12,*">
            <StackPanel Grid.Column="0" Spacing="6">
              <TextBlock Text="TARGET AMOUNT" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
              <TextBox Text="{Binding EditorTargetAmount}"/>
              <TextBlock Text="{Binding TargetAmountError}" FontSize="11" Foreground="#DC2626" IsVisible="{Binding HasTargetAmountError}"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="6">
              <TextBlock Text="CURRENCY" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
              <ComboBox ItemsSource="{Binding Currencies}" SelectedItem="{Binding EditorCurrency}" HorizontalAlignment="Stretch" MinHeight="44" FontSize="13" Background="#FFFFFF" Foreground="#111827" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8"/>
            </StackPanel>
          </Grid>
          <TextBlock Text="{Binding ErrorMessage}" IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Foreground="#DC2626" FontSize="12"/>
        </StackPanel>

        <Border Padding="24,18" BorderBrush="#F3F4F6" BorderThickness="0,1,0,0" Background="#FAFBFC">
          <Grid ColumnDefinitions="*,10,*">
            <Button Grid.Column="0" Command="{Binding CloseGoalEditorCommand}"
                    Theme="{StaticResource BtnSecondary}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="42">
              <TextBlock Text="Cancel"/>
            </Button>
            <Button Grid.Column="2" Command="{Binding SaveGoalCommand}"
                    Theme="{StaticResource BtnPrimary}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="42"
                    IsEnabled="{Binding !IsBusy}">
              <TextBlock Text="Save"/>
            </Button>
          </Grid>
        </Border>
      </StackPanel>
    </Border>
  </Border>

  <!-- Entry Editor -->
  <Border IsVisible="{Binding IsEntryEditorOpen}" Background="#00000050" CornerRadius="12">
    <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="400" Background="#FFFFFF" CornerRadius="16" BorderBrush="#E5E7EB" BorderThickness="1" BoxShadow="0 24 48 0 #30000000" ClipToBounds="True">
      <StackPanel>
        <Grid ColumnDefinitions="Auto,*,Auto" Margin="28,24,20,0">
          <Border Width="42" Height="42" CornerRadius="12" Background="#F0FDF4">
            <Path Data="{StaticResource IconIncome}" Stroke="#059669" StrokeThickness="1.8" Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center" Spacing="2">
            <TextBlock Text="Add Saving" FontSize="17" FontWeight="Bold" Foreground="#111827"/>
            <TextBlock Text="Record a savings entry" FontSize="12" Foreground="#9CA3AF"/>
          </StackPanel>
          <Button Grid.Column="2" Command="{Binding CloseEntryEditorCommand}" Background="Transparent" BorderThickness="0" Padding="10" CornerRadius="8" Cursor="Hand" VerticalAlignment="Top">
            <TextBlock Text="✕" FontSize="16" Foreground="#9CA3AF"/>
          </Button>
        </Grid>
        <Border Height="1" Background="#F3F4F6" Margin="0,20,0,0"/>

        <StackPanel Margin="28,20,28,8" Spacing="16">
          <StackPanel Spacing="6">
            <TextBlock Text="AMOUNT" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
            <TextBox Text="{Binding EditorEntryAmount}"/>
            <TextBlock Text="{Binding EntryAmountError}" FontSize="11" Foreground="#DC2626" IsVisible="{Binding HasEntryAmountError}"/>
          </StackPanel>
          <StackPanel Spacing="6">
            <TextBlock Text="DATE" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
            <DatePicker SelectedDate="{Binding EditorEntryDate}" HorizontalAlignment="Stretch"/>
          </StackPanel>
          <StackPanel Spacing="6">
            <TextBlock Text="NOTES" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
            <TextBox Text="{Binding EditorEntryNotes}" Watermark="Optional..."/>
          </StackPanel>
          <TextBlock Text="{Binding ErrorMessage}" IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Foreground="#DC2626" FontSize="12"/>
        </StackPanel>

        <Border Padding="24,18" BorderBrush="#F3F4F6" BorderThickness="0,1,0,0" Background="#FAFBFC">
          <Grid ColumnDefinitions="*,10,*">
            <Button Grid.Column="0" Command="{Binding CloseEntryEditorCommand}"
                    Theme="{StaticResource BtnSecondary}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="42">
              <TextBlock Text="Cancel"/>
            </Button>
            <Button Grid.Column="2" Command="{Binding SaveEntryCommand}"
                    Theme="{StaticResource BtnPrimary}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="42"
                    IsEnabled="{Binding !IsBusy}">
              <TextBlock Text="Add"/>
            </Button>
          </Grid>
        </Border>
      </StackPanel>
    </Border>
  </Border>

  <Border IsVisible="{Binding IsToastVisible}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,24" Padding="16,10" CornerRadius="10" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" BoxShadow="0 4 16 0 #40000000">
    <TextBlock Text="{Binding ToastMessage}" FontSize="13" Foreground="#111827"/>
  </Border>

  </Panel>
</UserControl>
