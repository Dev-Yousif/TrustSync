<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="YousifAccounting.Desktop.Views.Pages.PlaceholderView">
  <Grid Background="#F9FAFB">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
      <Border Width="64" Height="64" CornerRadius="32"
              Background="#F3F4F6" HorizontalAlignment="Center">
        <TextBlock Text="🚧" FontSize="28"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Border>
      <TextBlock x:Name="TitleText" Text="Coming Soon"
                 FontSize="20" FontWeight="SemiBold"
                 Foreground="#111827" HorizontalAlignment="Center"/>
      <TextBlock Text="This section is under development."
                 FontSize="14" Foreground="#6B7280" HorizontalAlignment="Center"/>
    </StackPanel>
  </Grid>
</UserControl>
