<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <x:Double x:Key="SpaceXXS">2</x:Double>
  <x:Double x:Key="SpaceXS">4</x:Double>
  <x:Double x:Key="SpaceSM">8</x:Double>
  <x:Double x:Key="SpaceMD">12</x:Double>
  <x:Double x:Key="SpaceLG">16</x:Double>
  <x:Double x:Key="SpaceXL">20</x:Double>
  <x:Double x:Key="SpaceXXL">24</x:Double>
  <x:Double x:Key="Space3XL">32</x:Double>
  <x:Double x:Key="Space4XL">40</x:Double>
  <x:Double x:Key="Space5XL">48</x:Double>

  <CornerRadius x:Key="RadiusSM">4</CornerRadius>
  <CornerRadius x:Key="RadiusMD">6</CornerRadius>
  <CornerRadius x:Key="RadiusLG">8</CornerRadius>
  <CornerRadius x:Key="RadiusXL">12</CornerRadius>

  <Thickness x:Key="BorderThin">1</Thickness>

</ResourceDictionary>
